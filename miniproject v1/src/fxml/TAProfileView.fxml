<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="profileViewPane" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TAProfileViewController">
    <!-- Navigation Bar -->
    <VBox styleClass="navbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24 20 24; -fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true;">
            <Label text="BUPT International School TA Recruitment System" styleClass="navbar-title" />
            <HBox style="-fx-spacing: 8; -fx-alignment: center; -fx-fill-width: true; -fx-max-width: infinity;">
                <Button text="Home" styleClass="navbar-menu" onAction="#handleHome" style="-fx-padding: 10px 24px; -fx-background-radius: 8px;" />
                <Button text="Application Management" styleClass="navbar-menu" onAction="#handleApplicationManagement" style="-fx-padding: 10px 24px; -fx-background-radius: 8px;" />
                <Button text="Personal Center" styleClass="navbar-menu active" onAction="#handlePersonalCenter" style="-fx-padding: 10px 24px; -fx-background-radius: 8px;" />
            </HBox>
            <HBox style="-fx-spacing: 16; -fx-alignment: center;">
                <Label text="Welcome, TA Applicant" textFill="rgba(255,255,255,0.85)" style="-fx-font-size: 14px;" />
                <Separator orientation="VERTICAL" styleClass="navbar-separator" />
                <Button text="Logout" styleClass="navbar-menu" onAction="#handleLogout" style="-fx-padding: 10px 16px; -fx-background-radius: 8px;" />
            </HBox>
        </HBox>
    </VBox>
    
    <!-- Main Content Area -->
    <ScrollPane style="-fx-background-color: #f8f9fa;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
        <VBox style="-fx-padding: 32px; -fx-spacing: 32px; -fx-fill-width: true; -fx-background-color: #f8f9fa; -fx-alignment: center; -fx-pref-width: 1200px;">
            <!-- Page Title -->
            <VBox alignment="CENTER" spacing="16">
                <Label text="Personal Profile" styleClass="section-title" style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" />
                <Label text="View your personal information" textFill="#6c757d" style="-fx-font-size: 16px; -fx-font-weight: 500;" />
            </VBox>
            
            <VBox styleClass="container shadow-lg" maxWidth="800" style="-fx-pref-width: 90%; -fx-background-color: #ffffff; -fx-background-radius: 12px;" spacing="32.0">
                <VBox style="-fx-padding: 32px; -fx-spacing: 24;">
                    <!-- Personal Basic Information -->
                    <VBox style="-fx-spacing: 16; -fx-padding: 0 0 24 0; -fx-border-width: 0 0 1 0; -fx-border-color: #e9ecef;">
                        <Label text="Personal Basic Information" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                        <GridPane hgap="16" vgap="12" style="-fx-pref-width: 100%;">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120" prefWidth="150" />
                                <ColumnConstraints minWidth="200" prefWidth="300" />
                                <ColumnConstraints minWidth="120" prefWidth="150" />
                                <ColumnConstraints minWidth="200" prefWidth="300" />
                            </columnConstraints>
                            
                            <Label text="Name: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                            <Label fx:id="nameLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529;" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                            
                            <Label text="Gender: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                            <Label fx:id="genderLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529;" GridPane.rowIndex="0" GridPane.columnIndex="3" />
                            
                            <Label text="Year of Birth: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                            <Label fx:id="ageLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529;" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                            
                            <Label text="Department: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                            <Label fx:id="departmentLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529;" GridPane.rowIndex="1" GridPane.columnIndex="3" />
                            
                            <Label text="Grade: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                            <Label fx:id="gradeLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529;" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                            
                            <Label text="Student ID: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="2" GridPane.columnIndex="2" />
                            <Label fx:id="studentIdLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529;" GridPane.rowIndex="2" GridPane.columnIndex="3" />
                        </GridPane>
                    </VBox>
                    
                    <!-- Work Availability -->
                    <VBox style="-fx-spacing: 16; -fx-padding: 0 0 24 0; -fx-border-width: 0 0 1 0; -fx-border-color: #e9ecef;">
                        <Label text="Work Availability" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                        <GridPane hgap="16" vgap="12" style="-fx-pref-width: 100%;">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120" prefWidth="150" />
                                <ColumnConstraints minWidth="400" prefWidth="600" />
                            </columnConstraints>
                            
                            <Label text="Available Work Time: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                            <Label fx:id="availableTimeLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529; -fx-wrap-text: true;" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                        </GridPane>
                    </VBox>
                    
                    <!-- Professional Skills and Experience -->
                    <VBox style="-fx-spacing: 16;">
                        <Label text="Professional Skills and Experience" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                        <GridPane hgap="16" vgap="12" style="-fx-pref-width: 100%;">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120" prefWidth="150" />
                                <ColumnConstraints minWidth="400" prefWidth="600" />
                            </columnConstraints>
                            
                            <Label text="Specialized Subjects/Skills: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                            <Label fx:id="skillsLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529; -fx-wrap-text: true;" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                            
                            <Label text="Previous TA Experience: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                            <Label fx:id="experienceLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529; -fx-wrap-text: true;" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                            
                            <Label text="Awards: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                            <Label fx:id="awardsLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529; -fx-wrap-text: true;" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                            
                            <Label text="Language Skills: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                            <Label fx:id="languageSkillsLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529; -fx-wrap-text: true;" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                            
                            <Label text="Other Special Skills: " style="-fx-font-size: 14px; -fx-text-fill: #495057;" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                            <Label fx:id="otherSkillsLabel" style="-fx-font-size: 14px; -fx-text-fill: #212529; -fx-wrap-text: true;" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                        </GridPane>
                    </VBox>
                    
                    <!-- Action Buttons -->
                    <HBox spacing="16.0" alignment="CENTER_RIGHT" style="-fx-spacing: 16; -fx-wrap-text: true; -fx-fill-width: true; -fx-padding: 24 0 0 0; -fx-border-width: 1 0 0 0; -fx-border-color: #e9ecef;">
                        <Button text="View Resume" styleClass="btn btn-secondary" onAction="#handleViewResume" style="-fx-pref-width: 120px; -fx-min-height: 40px;" />
                        <Button text="Edit" styleClass="btn btn-primary" onAction="#handleEditProfile" style="-fx-pref-width: 120px; -fx-min-height: 40px;" />
                        <Button text="Back" styleClass="btn btn-secondary" onAction="#handleBack" style="-fx-pref-width: 120px; -fx-min-height: 40px;" />
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>
</AnchorPane>