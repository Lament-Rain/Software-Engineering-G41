<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.beans.binding.*?>
<?import javafx.beans.property.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.util.*?>

<AnchorPane fx:id="taDashboardPane" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TADashboardController">
    <!-- Navigation Bar -->
    <VBox styleClass="navbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24 20 24; -fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true;">
            <Label text="BUPT International School TA Recruitment System" styleClass="navbar-title" />
            <HBox style="-fx-spacing: 8; -fx-alignment: center; -fx-fill-width: true; -fx-max-width: infinity;">
                <Button text="Home" styleClass="navbar-menu active" onAction="#handleHome" style="-fx-padding: 10px 24px; -fx-background-radius: 8px;" />
                <Button text="Job Requirements" styleClass="navbar-menu" onAction="#handleJobRequirements" style="-fx-padding: 10px 24px; -fx-background-radius: 8px;" />
                <Button text="Application Management" styleClass="navbar-menu" onAction="#handleApplicationManagement" style="-fx-padding: 10px 24px; -fx-background-radius: 8px;" />
                <Button text="Personal Center" styleClass="navbar-menu" onAction="#handlePersonalCenter" style="-fx-padding: 10px 24px; -fx-background-radius: 8px;" />
            </HBox>
            <HBox style="-fx-spacing: 16; -fx-alignment: center; -fx-min-width: 200px;">
                <Label text="Welcome, TA Applicant" textFill="rgba(255,255,255,0.85)" style="-fx-font-size: 14px; -fx-min-width: 120px;" />
                <Separator orientation="VERTICAL" styleClass="navbar-separator" />
                <Button text="Logout" styleClass="navbar-menu" onAction="#handleLogout" style="-fx-padding: 10px 16px; -fx-background-radius: 8px;" />
            </HBox>
        </HBox>
    </VBox>
    <!-- Main Content Area -->
    <ScrollPane style="-fx-background-color: #f8f9fa;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
        <VBox style="-fx-padding: 32px; -fx-spacing: 32px; -fx-fill-width: true; -fx-background-color: #f8f9fa; -fx-alignment: center; -fx-pref-width: 1200px; -fx-pref-height: -1;">
        <!-- Page Title -->
        <HBox alignment="CENTER_LEFT" style="-fx-spacing: 16; -fx-fill-width: true; -fx-padding: 0 0 16 0;">
            <VBox style="-fx-spacing: 8; -fx-pref-width: 100%;">
                <Label text="TA Applicant Dashboard" styleClass="section-title" style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" />
                <Label text="View your application status and available positions" textFill="#6c757d" style="-fx-font-size: 16px; -fx-font-weight: 500;" />
            </VBox>
        </HBox>
        
        <!-- Statistics Cards -->
        <HBox style="-fx-spacing: 24; -fx-fill-width: true; -fx-alignment: center;">
            <VBox styleClass="stat-card shadow-md" onMouseClicked="#handleOpenPositionsClick" style="-fx-pref-width: 32%; -fx-min-width: 200px; -fx-max-width: 300px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px; -fx-spacing: 16; -fx-alignment: center;">
                <Label text="📋" style="-fx-font-size: 32px;" />
                <Label fx:id="openPositionsLabel" text="12" styleClass="stat-value" />
                <Label text="Available Positions" styleClass="stat-label" />
            </VBox>
            <VBox styleClass="stat-card shadow-md" onMouseClicked="#handleMyApplicationsClick" style="-fx-pref-width: 32%; -fx-min-width: 200px; -fx-max-width: 300px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px; -fx-spacing: 16; -fx-alignment: center;">
                <Label text="👤" style="-fx-font-size: 32px;" />
                <Label fx:id="myApplicationsLabel" text="3" styleClass="stat-value" />
                <Label text="My Applications" styleClass="stat-label" />
            </VBox>
            <VBox styleClass="stat-card shadow-md" onMouseClicked="#handlePendingTasksClick" style="-fx-pref-width: 32%; -fx-min-width: 200px; -fx-max-width: 300px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px; -fx-spacing: 16; -fx-alignment: center;">
                <Label text="⏰" style="-fx-font-size: 32px;" />
                <Label fx:id="pendingActionsLabel" text="2" styleClass="stat-value" />
                <Label text="Pending Tasks" styleClass="stat-label" />
            </VBox>
        </HBox>
        
        <!-- Pending Tasks -->
        <VBox styleClass="card shadow-md" style="-fx-pref-height: 320px; -fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
            <HBox alignment="CENTER_LEFT" style="-fx-spacing: 16; -fx-fill-width: true; -fx-padding: 0 0 20 0;">
                <VBox style="-fx-spacing: 8;">
                    <Label text="Pending Tasks" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                    <Label text="Please complete these tasks before the deadline" textFill="#6c757d" style="-fx-font-size: 14px;" />
                </VBox>
            </HBox>
            <StackPane style="-fx-fill-width: true; -fx-pref-height: 240px;">
                <TableView fx:id="tasksTable" onMouseClicked="#handleTaskClick" style="-fx-pref-height: 240px; -fx-background-radius: 8px; -fx-border-radius: 8px; -fx-fill-width: true;">
                    <columns>
                        <TableColumn text="Task Name" prefWidth="600">
                            <cellValueFactory>
                                <PropertyValueFactory property="name" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Due Date" prefWidth="250">
                            <cellValueFactory>
                                <PropertyValueFactory property="dueDate" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Status" prefWidth="150">
                            <cellValueFactory>
                                <PropertyValueFactory property="status" />
                            </cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>
                <VBox fx:id="emptyTasksBox" visible="false" style="-fx-alignment: center; -fx-spacing: 16; -fx-padding: 40px;">
                    <Label text="📋" style="-fx-font-size: 48px;" />
                    <Label text="No pending tasks" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                    <Label text="Please complete your profile and apply for positions" textFill="#6c757d" style="-fx-font-size: 14px;" />
                </VBox>
            </StackPane>
        </VBox>
        
        <!-- Quick Actions -->
        <VBox styleClass="card shadow-md" style="-fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
            <Label text="Quick Actions" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057; -fx-padding: 0 0 20 0;" />
            <HBox style="-fx-spacing: 16; -fx-wrap-text: true; -fx-alignment: center-left; -fx-fill-width: true; -fx-min-width: 800px;">
                <Button text="Complete Personal Profile" styleClass="btn btn-primary" onAction="#handleUpdateProfile" style="-fx-pref-width: 200px; -fx-min-width: 200px; -fx-min-height: 44px; -fx-font-size: 15px;" />
                <Button text="Upload Resume" styleClass="btn btn-primary" onAction="#handleUploadResume" style="-fx-pref-width: 180px; -fx-min-width: 180px; -fx-min-height: 40px;" />
                <Button text="AI Job Matching" styleClass="btn btn-primary" onAction="#handleAIJobMatching" style="-fx-pref-width: 180px; -fx-min-width: 180px; -fx-min-height: 40px;" />
                <Button text="Skill Gap Analysis" styleClass="btn btn-secondary" onAction="#handleIdentifyMissingSkills" style="-fx-pref-width: 180px; -fx-min-width: 180px; -fx-min-height: 40px;" />
            </HBox>
        </VBox>
        </VBox>
    </ScrollPane>
</AnchorPane>