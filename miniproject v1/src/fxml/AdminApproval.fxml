<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminApprovalController">
    <VBox styleClass="navbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24 20 24; -fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true;">
            <Label text="BUPT International School TA Recruitment System" styleClass="navbar-title" />
            <HBox style="-fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true; -fx-max-width: infinity;">
                <Button text="Home" styleClass="navbar-menu" onAction="#handleHome" />
                <Button text="User Management" styleClass="navbar-menu" onAction="#handleUserManagement" />
                <Button text="Approval Center" styleClass="navbar-menu active" onAction="#handleApprovalCenter" />
            </HBox>
            <HBox style="-fx-spacing: 24; -fx-alignment: center;">
                <Label text="Welcome, Admin" textFill="rgba(255,255,255,0.85)" />
                <Separator orientation="VERTICAL" styleClass="navbar-separator" />
                <Button text="Logout" styleClass="navbar-menu" onAction="#handleLogout" />
            </HBox>
        </HBox>
    </VBox>

    <VBox spacing="24.0" style="-fx-padding: 32px; -fx-background-color: #f8f9fa;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
        <HBox alignment="CENTER_LEFT" spacing="16.0">
            <VBox spacing="6.0">
                <Label text="Admin Approval Center" styleClass="section-title" />
                <Label text="Review TA profiles in one place, including pending and completed records." textFill="#6c757d" style="-fx-font-size: 14px;" />
            </VBox>
        </HBox>

        <HBox spacing="20.0">
            <VBox styleClass="card shadow-md" spacing="12.0" style="-fx-pref-width: 320px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <Label text="Total Pending Reviews" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                <Label fx:id="pendingCountLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #f39c12;" />
            </VBox>
            <VBox styleClass="card shadow-md" spacing="12.0" style="-fx-pref-width: 320px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <Label text="Total Reviewed" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                <Label fx:id="reviewedCountLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #2ecc71;" />
            </VBox>
            <VBox styleClass="card shadow-md" spacing="12.0" style="-fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <Label fx:id="selectedTaLabel" text="No TA selected for review" style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                <Label fx:id="selectedProfileSummaryLabel" wrapText="true" text="Select a pending profile on the left, then add comments and complete the review on the right." textFill="#6c757d" style="-fx-font-size: 13px;" />
            </VBox>
        </HBox>

        <HBox spacing="24.0" VBox.vgrow="ALWAYS">
            <VBox spacing="16.0" styleClass="card shadow-md" style="-fx-pref-width: 780px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Pending Profiles" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                </HBox>
                <TableView fx:id="pendingTable" style="-fx-pref-height: 320px; -fx-fixed-cell-size: 36px; -fx-font-size: 12px;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="pendingUsernameCol" text="Username" prefWidth="120.0" />
                        <TableColumn fx:id="pendingNameCol" text="Name" prefWidth="120.0" />
                        <TableColumn fx:id="pendingDepartmentCol" text="Department" prefWidth="130.0" />
                        <TableColumn fx:id="pendingStudentIdCol" text="Student ID" prefWidth="130.0" />
                        <TableColumn fx:id="pendingResumeCol" text="Resume" prefWidth="90.0" />
                        <TableColumn fx:id="pendingStatusCol" text="Status" prefWidth="90.0" />
                        <TableColumn fx:id="pendingUpdatedAtCol" text="Updated At" prefWidth="230.0" />
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="16.0" styleClass="card shadow-md" style="-fx-pref-width: 360px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <Label text="Review Notes" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                <TextArea fx:id="reviewCommentArea" promptText="Enter review notes. Please include a reason when rejecting." prefRowCount="10" wrapText="true" />
                <HBox spacing="12.0">
                    <Button text="Approve" styleClass="btn btn-primary" onAction="#handleApprove" HBox.hgrow="ALWAYS" />
                    <Button text="Reject" styleClass="btn btn-danger" onAction="#handleReject" HBox.hgrow="ALWAYS" />
                </HBox>
                <Button text="Refresh List" styleClass="btn btn-secondary" onAction="#handleRefresh" maxWidth="1.7976931348623157E308" />
            </VBox>
        </HBox>

        <VBox spacing="16.0" styleClass="card shadow-md" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;" VBox.vgrow="ALWAYS">
            <Label text="Reviewed Records" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
            <TableView fx:id="reviewedTable" style="-fx-pref-height: 250px; -fx-fixed-cell-size: 36px; -fx-font-size: 12px;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="reviewedUsernameCol" text="Username" prefWidth="120.0" />
                    <TableColumn fx:id="reviewedNameCol" text="Name" prefWidth="110.0" />
                    <TableColumn fx:id="reviewedDepartmentCol" text="Department" prefWidth="130.0" />
                    <TableColumn fx:id="reviewedStudentIdCol" text="Student ID" prefWidth="130.0" />
                    <TableColumn fx:id="reviewedStatusCol" text="Result" prefWidth="90.0" />
                    <TableColumn fx:id="reviewedCommentCol" text="Review Notes" prefWidth="320.0" />
                    <TableColumn fx:id="reviewedUpdatedAtCol" text="Updated At" prefWidth="230.0" />
                </columns>
            </TableView>
        </VBox>
    </VBox>
</AnchorPane>
