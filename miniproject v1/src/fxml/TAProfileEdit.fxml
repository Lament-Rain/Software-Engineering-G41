<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>

<AnchorPane fx:id="profileEditPane" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TAProfileEditController">
    <fx:define>
        <ToggleGroup fx:id="genderToggleGroup" />
    </fx:define>
    <!-- Navigation Bar -->
    <VBox styleClass="navbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 16 24; -fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true; -fx-background-color: #2c3e50;">
            <Label text="BUPT International School TA Recruitment System" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" />
            <HBox style="-fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true; -fx-max-width: infinity;">
                <Button text="Home" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-padding: 8 16;" onAction="#handleHome" />
                <Button text="Job Requirements" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-padding: 8 16;" onAction="#handleJobRequirements" />
                <Button text="Application Management" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.85); -fx-padding: 8 16;" onAction="#handleApplicationManagement" />
                <Button text="Personal Center" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4px;" />
            </HBox>
            <HBox alignment="CENTER_RIGHT" style="-fx-spacing: 16; -fx-alignment: center;">
                <Label text="Welcome, TA Applicant" textFill="rgba(255,255,255,0.85)" />
                <Button text="Back to TA Dashboard" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-padding: 6 12; -fx-background-radius: 4px;" onAction="#handleBack" />
                <Button text="Logout" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-padding: 6 12; -fx-background-radius: 4px;" onAction="#handleLogout" />
            </HBox>
        </HBox>
    </VBox>
    
    <!-- Breadcrumb Navigation -->
    <HBox layoutY="56.0" style="-fx-padding: 12 24; -fx-background-color: #f8f9fa;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <Button text="Home" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #6c757d; -fx-padding: 0;" onAction="#handleHome" />
        <Label text=" > " style="-fx-text-fill: #6c757d;" />
        <Label text="Complete Personal Profile" style="-fx-text-fill: #0d6efd; -fx-font-weight: bold;" />
    </HBox>
    
    <!-- Main Content Area -->
    <VBox layoutY="92.0" spacing="16.0" style="-fx-padding: 24px; -fx-fill-width: true; -fx-background-color: #f8f9fa;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="92.0">
        <!-- Task Header -->
        <HBox alignment="CENTER_LEFT" spacing="24.0" style="-fx-pref-width: 100%;">
            <VBox spacing="4.0">
                <Label text="Complete Personal Profile" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
                <Label text="Please fill in the following information to complete your profile, * indicates required fields" style="-fx-font-size: 13px; -fx-text-fill: #6c757d;" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT" spacing="4.0">
                <Label fx:id="progressLabel" text="Completed 0/8 required items" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d6efd;" />
                <ProgressBar fx:id="progressBar" progress="0.0" style="-fx-pref-width: 150px; -fx-pref-height: 6px;" />
            </VBox>
        </HBox>
        
        <!-- Task Count Prompt -->
        <Label text="Total 8 required items, 3 optional items" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
        
        <!-- Module Navigation -->
        <HBox spacing="12.0" style="-fx-padding: 12px; -fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);">
            <Button fx:id="personalInfoBtn" text="Personal Basic Information" style="-fx-background-color: #e3f2fd; -fx-text-fill: #0d6efd; -fx-padding: 6 12; -fx-background-radius: 4px; -fx-font-weight: bold;" onAction="#scrollToPersonalInfo" />
            <Button fx:id="workAvailabilityBtn" text="Work Availability" style="-fx-background-color: transparent; -fx-text-fill: #6c757d; -fx-padding: 6 12; -fx-background-radius: 4px;" onAction="#scrollToWorkAvailability" />
            <Button fx:id="professionalSkillsBtn" text="Professional Skills and Experience" style="-fx-background-color: transparent; -fx-text-fill: #6c757d; -fx-padding: 6 12; -fx-background-radius: 4px;" onAction="#scrollToProfessionalSkills" />
        </HBox>
        
        <!-- 滚动面板 -->
        <ScrollPane fx:id="scrollPane" style="-fx-pref-width: 100%; -fx-pref-height: 520px; -fx-background-color: transparent; -fx-border-color: transparent;" fitToWidth="true" VBox.vgrow="ALWAYS">
            <VBox style="-fx-background-color: #ffffff; -fx-background-radius: 8px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2); -fx-pref-width: 100%;" spacing="24.0">
                <!-- Personal Basic Information Module -->
                <VBox fx:id="personalInfoModule" style="-fx-padding: 24px; -fx-background-color: #f8f9fa; -fx-background-radius: 8px; margin: 16px;" spacing="16">
                    <Label text="Personal Basic Information" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
                    <GridPane hgap="16.0" vgap="16.0" style="-fx-pref-width: 100%;">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                        </columnConstraints>
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="8.0" style="-fx-pref-width: 100%;">
                            <HBox spacing="4.0" alignment="CENTER_LEFT">
                                <Label text="Name" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                                <Label text="*" style="-fx-font-size: 16px; -fx-text-fill: #dc3545;" />
                            </HBox>
                            <TextField fx:id="nameField" style="-fx-pref-width: 100%; -fx-min-height: 40px; -fx-background-radius: 4px; -fx-border-color: #dee2e6; -fx-border-radius: 4px;" />
                            <Label text="Please enter your name" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                        </VBox>
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="8.0" style="-fx-pref-width: 100%;">
                            <HBox spacing="4.0" alignment="CENTER_LEFT">
                                <Label text="Gender" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                                <Label text="*" style="-fx-font-size: 16px; -fx-text-fill: #dc3545;" />
                            </HBox>
                            <HBox spacing="16.0">
                                <RadioButton text="Male" style="-fx-font-size: 14px;" toggleGroup="$genderToggleGroup" fx:id="genderMaleRadio" />
                                <RadioButton text="Female" style="-fx-font-size: 14px;" toggleGroup="$genderToggleGroup" fx:id="genderFemaleRadio" />
                            </HBox>
                        </VBox>
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="8.0" style="-fx-pref-width: 100%;">
                            <HBox spacing="4.0" alignment="CENTER_LEFT">
                                <Label text="Department" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                                <Label text="*" style="-fx-font-size: 16px; -fx-text-fill: #dc3545;" />
                            </HBox>
                            <TextField fx:id="departmentField" style="-fx-pref-width: 100%; -fx-min-height: 40px; -fx-background-radius: 4px; -fx-border-color: #dee2e6; -fx-border-radius: 4px;" />
                            <Label text="Please enter your department" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                        </VBox>
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="8.0" style="-fx-pref-width: 100%;">
                            <Label text="Year of Birth (Optional)" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                            <TextField fx:id="ageField" style="-fx-pref-width: 100%; -fx-min-height: 40px; -fx-background-radius: 4px; -fx-border-color: #dee2e6; -fx-border-radius: 4px;" />
                            <Label text="Please enter your year of birth, e.g.: 2000" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                        </VBox>
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" spacing="8.0" style="-fx-pref-width: 100%;">
                            <HBox spacing="4.0" alignment="CENTER_LEFT">
                                <Label text="Grade" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                                <Label text="*" style="-fx-font-size: 16px; -fx-text-fill: #dc3545;" />
                            </HBox>
                            <TextField fx:id="gradeField" style="-fx-pref-width: 100%; -fx-min-height: 40px; -fx-background-radius: 4px; -fx-border-color: #dee2e6; -fx-border-radius: 4px;" />
                            <Label text="Please enter your enrollment grade, e.g.: 2022" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                        </VBox>
                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="2" spacing="8.0" style="-fx-pref-width: 100%;">
                            <HBox spacing="4.0" alignment="CENTER_LEFT">
                                <Label text="Student ID" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                                <Label text="*" style="-fx-font-size: 16px; -fx-text-fill: #dc3545;" />
                            </HBox>
                            <TextField fx:id="studentIdField" style="-fx-pref-width: 100%; -fx-min-height: 40px; -fx-background-radius: 4px; -fx-border-color: #dee2e6; -fx-border-radius: 4px;" />
                            <Label text="Please enter the correct student ID format, e.g.: 2022211234" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                        </VBox>
                    </GridPane>
                </VBox>
                
                <!-- Work Availability Module -->
                <VBox fx:id="workAvailabilityModule" style="-fx-padding: 24px; -fx-background-color: #f8f9fa; -fx-background-radius: 8px; margin: 16px;" spacing="16">
                    <Label text="Work Availability" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
                    <VBox spacing="16.0" style="-fx-pref-width: 100%;">
                        <VBox spacing="8.0" style="-fx-pref-width: 100%;">
                            <HBox spacing="4.0" alignment="CENTER_LEFT">
                                <Label text="Available Work Time" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                                <Label text="*" style="-fx-font-size: 16px; -fx-text-fill: #dc3545;" />
                            </HBox>
                            <TextArea fx:id="availableTimeField" prefHeight="80.0" style="-fx-pref-width: 100%; -fx-min-height: 80px; -fx-background-radius: 4px; -fx-border-color: #dee2e6; -fx-border-radius: 4px;" />
                            <Label text="You can enter multiple time slots, separated by new lines, e.g.: Monday to Friday 18:00-22:00; Saturday 10:00-18:00" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                        </VBox>
                        <VBox spacing="8.0" style="-fx-pref-width: 100%;">
                            <HBox spacing="4.0" alignment="CENTER_LEFT">
                                <Label text="Specialized Subjects/Skills" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                                <Label text="*" style="-fx-font-size: 16px; -fx-text-fill: #dc3545;" />
                            </HBox>
                            <TextField fx:id="skillsField" style="-fx-pref-width: 100%; -fx-min-height: 40px; -fx-background-radius: 4px; -fx-border-color: #dee2e6; -fx-border-radius: 4px;" />
                            <Label text="e.g.: Java; Python; Advanced Mathematics (separate multiple subjects/skills with semicolons (;))" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                        </VBox>
                    </VBox>
                </VBox>
                
                <!-- Professional Skills and Experience Module -->
                <VBox fx:id="professionalSkillsModule" style="-fx-padding: 24px; -fx-background-color: #f8f9fa; -fx-background-radius: 8px; margin: 16px;" spacing="16">
                    <Label text="Professional Skills and Experience" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
                    <VBox spacing="16.0" style="-fx-pref-width: 100%;">
                        <VBox spacing="8.0" style="-fx-pref-width: 100%;">
                            <HBox spacing="4.0" alignment="CENTER_LEFT">
                                <Label text="Previous TA Experience" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                                <Label text="*" style="-fx-font-size: 16px; -fx-text-fill: #dc3545;" />
                            </HBox>
                            <TextArea fx:id="experienceField" prefHeight="120.0" style="-fx-pref-width: 100%; -fx-min-height: 120px; -fx-background-radius: 4px; -fx-border-color: #dee2e6; -fx-border-radius: 4px;" />
                            <Label text="Please describe the course names you served as TA, work content (such as grading homework, answering questions), duration and achievements" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                        </VBox>
                        <VBox spacing="8.0" style="-fx-pref-width: 100%;">
                            <Label text="Awards (Optional)" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                            <TextArea fx:id="awardsField" prefHeight="80.0" style="-fx-pref-width: 100%; -fx-min-height: 80px; -fx-background-radius: 4px; -fx-border-color: #dee2e6; -fx-border-radius: 4px;" />
                        </VBox>
                        <VBox spacing="8.0" style="-fx-pref-width: 100%;">
                            <Label text="Language Skills (Optional)" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                            <TextField fx:id="languageSkillsField" style="-fx-pref-width: 100%; -fx-min-height: 40px; -fx-background-radius: 4px; -fx-border-color: #dee2e6; -fx-border-radius: 4px;" />
                        </VBox>
                        <VBox spacing="8.0" style="-fx-pref-width: 100%;">
                            <Label text="Other Special Skills (Optional)" style="-fx-font-size: 16px; -fx-text-fill: #212529;" />
                            <TextArea fx:id="otherSkillsField" prefHeight="80.0" style="-fx-pref-width: 100%; -fx-min-height: 80px; -fx-background-radius: 4px; -fx-border-color: #dee2e6; -fx-border-radius: 4px;" />
                        </VBox>
                    </VBox>
                </VBox>
                
                <Label fx:id="messageLabel" style="-fx-padding: 0 24px; -fx-font-size: 14px; -fx-text-fill: #dc3545;" />
                
                <!-- Action Buttons -->
                <HBox spacing="12.0" alignment="CENTER_RIGHT" style="-fx-spacing: 12; -fx-wrap-text: true; -fx-pref-width: 100%; -fx-padding: 0 24px 24px 24px;">
                    <Button text="Reset" style="-fx-pref-width: 100px; -fx-min-height: 40px; -fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 4px; -fx-font-weight: bold;" onAction="#handleReset" />
                    <Button text="Save Draft" style="-fx-pref-width: 100px; -fx-min-height: 40px; -fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 4px; -fx-font-weight: bold;" onAction="#handleSaveDraft" />
                    <Button text="Submit" style="-fx-pref-width: 100px; -fx-min-height: 40px; -fx-background-color: #0d6efd; -fx-text-fill: white; -fx-background-radius: 4px; -fx-font-weight: bold;" onAction="#handleSubmitForReview" />
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
