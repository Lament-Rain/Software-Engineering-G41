<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.beans.binding.*?>
<?import javafx.beans.property.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.util.*?>

<AnchorPane fx:id="moDashboardPane" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MODashboardController">
    <!-- Navigation Bar -->
    <VBox styleClass="navbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24 20 24; -fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true;">
            <Label text="BUPT International School TA Recruitment System" styleClass="navbar-title" />
            <HBox style="-fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true; -fx-max-width: infinity;">
                <Button text="Home" styleClass="navbar-menu active" onAction="#handleHome" />
                <Button text="Job Management" styleClass="navbar-menu" onAction="#handleJobManagement" />
                <Button text="Application Management" styleClass="navbar-menu" onAction="#handleApplicationManagement" />
                <Button text="Statistics" styleClass="navbar-menu" onAction="#handleStatisticsAnalysis" />
            </HBox>
            <HBox style="-fx-spacing: 24; -fx-alignment: center;">
                <Label text="Welcome, Module Organizer" textFill="rgba(255,255,255,0.85)" />
                <Separator orientation="VERTICAL" styleClass="navbar-separator" />
                <Button text="Logout" styleClass="navbar-menu" onAction="#handleLogout" />
            </HBox>
        </HBox>
    </VBox>
    <!-- Main Content -->
    <ScrollPane style="-fx-background-color: #f8f9fa;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
        <VBox style="-fx-padding: 32px; -fx-spacing: 32px; -fx-fill-width: true; -fx-background-color: #f8f9fa; -fx-alignment: center; -fx-pref-width: 1200px;">
            <!-- Page Title -->
            <HBox alignment="CENTER_LEFT" style="-fx-spacing: 16; -fx-fill-width: true;">
                <VBox style="-fx-spacing: 8;">
                    <Label text="Module Organizer Dashboard" styleClass="section-title" />
                    <Label text="Manage job posting and application review" textFill="#6c757d" style="-fx-font-size: 14px;" />
                </VBox>
            </HBox>
            
            <!-- Statistics Cards -->
            <HBox style="-fx-spacing: 24; -fx-fill-width: true; -fx-alignment: center;">
                <VBox styleClass="stat-card shadow-md" style="-fx-pref-width: 32%; -fx-min-width: 200px; -fx-max-width: 300px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px; -fx-spacing: 16;">
                    <Label text="📋" style="-fx-font-size: 32px;" />
                    <Label fx:id="publishedJobsLabel" text="0" styleClass="stat-value" />
                    <Label text="Published Jobs" styleClass="stat-label" />
                </VBox>
                <VBox styleClass="stat-card shadow-md" style="-fx-pref-width: 32%; -fx-min-width: 200px; -fx-max-width: 300px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px; -fx-spacing: 16;">
                    <Label text="👥" style="-fx-font-size: 32px;" />
                    <Label fx:id="totalApplicationsLabel" text="0" styleClass="stat-value" />
                    <Label text="Total Applications" styleClass="stat-label" />
                </VBox>
                <VBox styleClass="stat-card shadow-md" style="-fx-pref-width: 32%; -fx-min-width: 200px; -fx-max-width: 300px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px; -fx-spacing: 16;">
                    <Label text="✅" style="-fx-font-size: 32px;" />
                    <Label fx:id="acceptedApplicationsLabel" text="0" styleClass="stat-value" />
                    <Label text="Accepted TAs" styleClass="stat-label" />
                </VBox>
            </HBox>
            
            <!-- Recently Published Jobs -->
            <VBox styleClass="card shadow-md" style="-fx-pref-height: 320px; -fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <HBox alignment="CENTER_LEFT" style="-fx-spacing: 16; -fx-fill-width: true; -fx-padding: 0 0 20 0;">
                    <VBox style="-fx-spacing: 8;">
                        <Label text="Recently Published Jobs" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                        <Label text="View and manage your published jobs" textFill="#6c757d" style="-fx-font-size: 14px;" />
                    </VBox>
                </HBox>
                <TableView fx:id="jobsTable" style="-fx-pref-height: 240px; -fx-background-radius: 8px; -fx-border-radius: 8px;">
                    <columns>
                        <TableColumn text="Job Title" style="-fx-pref-width: 40%;">
                            <cellValueFactory>
                                <PropertyValueFactory property="title" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Department" style="-fx-pref-width: 25%;">
                            <cellValueFactory>
                                <PropertyValueFactory property="department" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Deadline" style="-fx-pref-width: 25%;">
                            <cellValueFactory>
                                <PropertyValueFactory property="deadline" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Applications" style="-fx-pref-width: 10%;">
                            <cellValueFactory>
                                <PropertyValueFactory property="applicationCount" />
                            </cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>
            </VBox>
            
            <!-- Quick Actions -->
            <VBox styleClass="card shadow-md" style="-fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <Label text="Quick Actions" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057; -fx-padding: 0 0 20 0;" />
                <HBox style="-fx-spacing: 16; -fx-wrap-text: true; -fx-alignment: center-left; -fx-fill-width: true;">
                <Button text="Post New Job" styleClass="btn btn-primary" onAction="#handleCreateJob" style="-fx-pref-width: 180px; -fx-min-height: 40px;" />
                <Button text="View All Jobs" styleClass="btn btn-primary" onAction="#handleViewAllJobs" style="-fx-pref-width: 180px; -fx-min-height: 40px;" />
                <Button text="View Applications" styleClass="btn btn-primary" onAction="#handleViewApplications" style="-fx-pref-width: 180px; -fx-min-height: 40px;" />
                <Button text="Export Data" styleClass="btn btn-secondary" onAction="#handleExportData" style="-fx-pref-width: 180px; -fx-min-height: 40px;" />
                <Button text="View Statistics" styleClass="btn btn-secondary" onAction="#handleViewStatistics" style="-fx-pref-width: 180px; -fx-min-height: 40px;" />
            </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</AnchorPane>
