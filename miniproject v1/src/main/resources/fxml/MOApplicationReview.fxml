<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MOApplicationReviewController">
    <VBox styleClass="navbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24 20 24; -fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true;">
            <Label text="BUPT International School TA Recruitment System" styleClass="navbar-title" />
            <HBox style="-fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true; -fx-max-width: infinity;" />
            <Button text="Back to MO Dashboard" styleClass="navbar-menu" onAction="#handleBack" />
        </HBox>
    </VBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: #f8f9fa;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
        <VBox style="-fx-padding: 32px; -fx-spacing: 24px; -fx-background-color: #f8f9fa; -fx-pref-width: 1240px;">
            <VBox style="-fx-spacing: 8;">
                <Label text="Application Review" style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" />
                <Label text="Select a job you published, review applicants and perform screening / accept / reject." textFill="#6c757d" style="-fx-font-size: 14px;" />
            </VBox>

            <VBox styleClass="card shadow-md" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 20px; -fx-spacing: 16;">
                <Label text="Select Job" style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                <ComboBox fx:id="jobSelector" promptText="Select a job" style="-fx-pref-width: 420px;" />
            </VBox>

            <HBox style="-fx-spacing: 18;">
                <VBox styleClass="stat-card shadow-md" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 20px; -fx-spacing: 10; -fx-pref-width: 220px;">
                    <Label text="Total Applicants" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                    <Label fx:id="applicantCountLabel" text="0" style="-fx-font-size: 30px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" />
                </VBox>
                <VBox styleClass="stat-card shadow-md" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 20px; -fx-spacing: 10; -fx-pref-width: 220px;">
                    <Label text="Accepted" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                    <Label fx:id="acceptedCountLabel" text="0" style="-fx-font-size: 30px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" />
                </VBox>
                <VBox styleClass="stat-card shadow-md" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 20px; -fx-spacing: 10; -fx-pref-width: 220px;">
                    <Label text="Pending / Screened" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                    <Label fx:id="pendingCountLabel" text="0" style="-fx-font-size: 30px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" />
                </VBox>
            </HBox>

            <HBox spacing="24" alignment="TOP_LEFT">
                <VBox styleClass="card shadow-md" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 20px; -fx-spacing: 16; -fx-pref-width: 770px;">
                    <Label text="Applicant List" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                    <TableView fx:id="applicantsTable" style="-fx-pref-height: 500px;">
                        <columns>
                            <TableColumn fx:id="nameColumn" text="Applicant" prefWidth="150" />
                            <TableColumn fx:id="departmentColumn" text="Department" prefWidth="120" />
                            <TableColumn fx:id="submittedAtColumn" text="Submitted At" prefWidth="150" />
                            <TableColumn fx:id="statusColumn" text="Status" prefWidth="110" />
                            <TableColumn fx:id="matchScoreColumn" text="Match Score" prefWidth="100" />
                            <TableColumn fx:id="resumeStatusColumn" text="Resume" prefWidth="110" />
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="card shadow-md" style="-fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 20px; -fx-spacing: 16; -fx-pref-width: 390px;">
                    <Label fx:id="selectedJobLabel" text="No job selected" style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" wrapText="true" />
                    <Separator />
                    <Label text="Applicant" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                    <Label fx:id="applicantNameLabel" text="No applicant selected" style="-fx-font-size: 16px; -fx-font-weight: 600;" />
                    <Label text="Status" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                    <Label fx:id="applicantStatusLabel" text="-" />
                    <Label text="Resume" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                    <Label fx:id="applicantResumeLabel" text="-" />
                    <Label text="Experience" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                    <TextArea fx:id="experienceArea" editable="false" wrapText="true" style="-fx-pref-height: 95px;" />
                    <Label text="Cover Letter" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                    <TextArea fx:id="coverLetterArea" editable="false" wrapText="true" style="-fx-pref-height: 110px;" />
                    <Label text="Feedback / Review Comment" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                    <TextArea fx:id="feedbackArea" wrapText="true" promptText="Shortlist note or rejection reason" style="-fx-pref-height: 110px;" />
                    <HBox style="-fx-spacing: 10; -fx-alignment: center-left;">
                        <Button fx:id="screenButton" text="Mark Screened" onAction="#handleScreenApplicant" styleClass="btn btn-secondary" style="-fx-pref-width: 110px;" />
                        <Button fx:id="acceptButton" text="Accept" onAction="#handleAcceptApplicant" styleClass="btn btn-primary" style="-fx-pref-width: 90px;" />
                        <Button fx:id="rejectButton" text="Reject" onAction="#handleRejectApplicant" styleClass="btn btn-secondary" style="-fx-pref-width: 90px;" />
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </ScrollPane>
</AnchorPane>
