<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.JobDetailController">
    <!-- 导航栏 -->
    <VBox styleClass="navbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24 20 24; -fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true;">
            <Label text="BUPT国际学校TA招聘系统" styleClass="navbar-title" />
            <HBox style="-fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true; -fx-max-width: infinity;" />
            <HBox style="-fx-spacing: 24; -fx-alignment: center;">
                <Label text="职位详情" textFill="rgba(255,255,255,0.85)" />
                <Separator orientation="VERTICAL" styleClass="navbar-separator" />
                <Button text="退出" styleClass="navbar-menu" onAction="#handleLogout" />
            </HBox>
        </HBox>
    </VBox>

    <!-- 主内容区 -->
    <ScrollPane style="-fx-background-color: #f8f9fa;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
        <VBox style="-fx-padding: 32px; -fx-spacing: 24px; -fx-fill-width: true; -fx-background-color: #f8f9fa; -fx-alignment: center; -fx-pref-width: 1000px;">

            <!-- 页面标题 -->
            <HBox alignment="CENTER_LEFT" style="-fx-spacing: 16; -fx-fill-width: true;">
                <VBox style="-fx-spacing: 8;">
                    <Label text="职位详情" styleClass="section-title" style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;" />
                    <Label text="查看职位详细信息" textFill="#6c757d" style="-fx-font-size: 14px;" />
                </VBox>
            </HBox>

            <!-- 基本信息卡片 -->
            <VBox styleClass="card shadow-md" style="-fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <Label fx:id="titleLabel" text="职位标题" style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #2c3e50; -fx-padding: 0 0 16 0;" />

                <GridPane vgap="12" hgap="30" style="-fx-fill-width: true;">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="120" />
                        <ColumnConstraints minWidth="200" prefWidth="250" />
                        <ColumnConstraints minWidth="100" prefWidth="120" />
                        <ColumnConstraints minWidth="200" prefWidth="250" />
                    </columnConstraints>

                    <!-- 第一行 -->
                    <Label text="院系:" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <Label fx:id="departmentLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <Label text="职位类型:" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                    <Label fx:id="typeLabel" text="-" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                    <!-- 第二行 -->
                    <Label text="工作时间:" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <Label fx:id="workTimeLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label text="招募人数:" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                    <Label fx:id="recruitNumLabel" text="-" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                    <!-- 第三行 -->
                    <Label text="截止日期:" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <Label fx:id="deadlineLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <Label text="薪资待遇:" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                    <Label fx:id="salaryLabel" text="-" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                    <!-- 第四行 -->
                    <Label text="工作地点:" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                    <Label fx:id="locationLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <Label text="状态:" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                    <Label fx:id="statusLabel" text="-" GridPane.columnIndex="3" GridPane.rowIndex="3" />

                    <!-- 第五行 -->
                    <Label text="发布者:" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                    <Label fx:id="publisherLabel" text="-" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                    <Label text="发布日期:" style="-fx-font-weight: bold; -fx-text-fill: #495057;" GridPane.columnIndex="2" GridPane.rowIndex="4" />
                    <Label fx:id="publishDateLabel" text="-" GridPane.columnIndex="3" GridPane.rowIndex="4" />
                </GridPane>
            </VBox>

            <!-- 职位描述 -->
            <VBox styleClass="card shadow-md" style="-fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <Label text="职位描述" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057; -fx-padding: 0 0 12 0;" />
                <TextArea fx:id="descriptionArea" editable="false" wrapText="true" style="-fx-pref-height: 150px; -fx-background-radius: 8px;" />
            </VBox>

            <!-- 技能要求 -->
            <VBox styleClass="card shadow-md" style="-fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <Label text="技能要求" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057; -fx-padding: 0 0 12 0;" />
                <TextArea fx:id="skillsArea" editable="false" wrapText="true" style="-fx-pref-height: 120px; -fx-background-radius: 8px;" />
            </VBox>

            <!-- 额外要求 -->
            <VBox styleClass="card shadow-md" style="-fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <Label text="额外要求" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057; -fx-padding: 0 0 12 0;" />
                <TextArea fx:id="extraRequirementsArea" editable="false" wrapText="true" style="-fx-pref-height: 100px; -fx-background-radius: 8px;" />
            </VBox>

            <!-- 操作按钮 -->
            <HBox style="-fx-spacing: 16; -fx-alignment: center-left;">
                <Button fx:id="backButton" text="返回列表" styleClass="btn btn-secondary" onAction="#handleBack" style="-fx-pref-width: 120px; -fx-min-height: 40px;" />
                <Button fx:id="applyButton" text="申请职位" styleClass="btn btn-primary" onAction="#handleApply" style="-fx-pref-width: 120px; -fx-min-height: 40px;" />
            </HBox>

        </VBox>
    </ScrollPane>
</AnchorPane>
