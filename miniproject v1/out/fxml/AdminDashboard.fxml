<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.beans.binding.*?>
<?import javafx.beans.property.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.util.*?>

<AnchorPane fx:id="adminDashboardPane" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminDashboardController">
    <!-- 导航栏 -->
    <VBox styleClass="navbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-spacing: 20;">
            <Label text="BUPT国际学校TA招聘系统" styleClass="navbar-title" />
            <HBox spacing="15.0" style="-fx-spacing: 15;">
                <Button text="首页" styleClass="navbar-menu" />
                <Button text="用户管理" styleClass="navbar-menu" />
                <Button text="职位管理" styleClass="navbar-menu" />
                <Button text="系统配置" styleClass="navbar-menu" />
                <Button text="统计分析" styleClass="navbar-menu" />
            </HBox>
        </HBox>
    </VBox>
    <!-- 主内容区 -->
    <VBox layoutY="60.0" style="-fx-padding: 20px; -fx-spacing: 20px;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="60.0">
        <Label text="Admin Dashboard" styleClass="section-title" textFill="#6c757d" />
        <!-- 统计卡片 -->
        <HBox spacing="20.0" style="-fx-spacing: 20;">
            <VBox styleClass="stat-card" style="-fx-pref-width: 30%; -fx-min-width: 180px;">
                <Label text="👥" />
                <Label fx:id="totalUsersLabel" text="50" styleClass="stat-value" />
                <Label text="Total Users" styleClass="stat-label" />
            </VBox>
            <VBox styleClass="stat-card" style="-fx-pref-width: 30%; -fx-min-width: 180px;">
                <Label text="📋" />
                <Label fx:id="totalJobsLabel" text="25" styleClass="stat-value" />
                <Label text="Total Jobs" styleClass="stat-label" />
            </VBox>
            <VBox styleClass="stat-card" style="-fx-pref-width: 30%; -fx-min-width: 180px;">
                <Label text="📄" />
                <Label fx:id="totalApplicationsLabel" text="120" styleClass="stat-value" />
                <Label text="Total Applications" styleClass="stat-label" />
            </VBox>
        </HBox>
        <!-- 系统状态 -->
        <VBox styleClass="card" style="-fx-pref-height: 300px;">
            <Label text="System Status" />
            <TableView fx:id="systemStatusTable" style="-fx-pref-height: 250px; -fx-fill-width: true;">
                <columns>
                    <TableColumn text="Item" style="-fx-pref-width: 30%;">
                        <cellValueFactory>
                            <PropertyValueFactory property="item" />
                        </cellValueFactory>
                    </TableColumn>
                    <TableColumn text="Status" style="-fx-pref-width: 20%;">
                        <cellValueFactory>
                            <PropertyValueFactory property="status" />
                        </cellValueFactory>
                        <cellFactory>
                            <Callback>
                                <TableCell fx:factory="forTableColumn">
                                    <text>
                                        <Bindings when="${cellValue == 'Active'}">
                                            <Label text="${cellValue}" styleClass="status-approved" />
                                        </Bindings>
                                        <Bindings when="${cellValue == 'Inactive'}">
                                            <Label text="${cellValue}" styleClass="status-rejected" />
                                        </Bindings>
                                    </text>
                                </TableCell>
                            </Callback>
                        </cellFactory>
                    </TableColumn>
                    <TableColumn text="Details" style="-fx-pref-width: 50%;">
                        <cellValueFactory>
                            <PropertyValueFactory property="details" />
                        </cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
        </VBox>
        <!-- 快速操作按钮 -->
        <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-spacing: 10; -fx-wrap-text: true;">
            <Button text="管理员配置" styleClass="btn btn-primary" onAction="#handleAdminConfiguration" />
            <Button text="报告定时生成" styleClass="btn btn-primary" onAction="#handleScheduleReports" />
            <Button text="批量操作" styleClass="btn btn-primary" onAction="#handleBulkOperations" />
            <Button text="AI工作量平衡" styleClass="btn btn-secondary" onAction="#handleAIWorkloadBalancing" />
        </HBox>
    </VBox>
</AnchorPane>