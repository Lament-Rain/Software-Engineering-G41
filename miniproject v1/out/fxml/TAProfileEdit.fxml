<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="profileEditPane" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TAProfileEditController">
    <!-- 导航栏 -->
    <VBox styleClass="navbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 40; -fx-spacing: 40; -fx-alignment: center;">
            <Label text="BUPT国际学校TA招聘系统" styleClass="navbar-title" />
            <HBox style="-fx-spacing: 24; -fx-alignment: center;">
                <Button text="首页" styleClass="navbar-menu" />
                <Button text="职位管理" styleClass="navbar-menu" />
                <Button text="申请管理" styleClass="navbar-menu" />
                <Button text="个人中心" styleClass="navbar-menu" />
            </HBox>
            <HBox alignment="CENTER_RIGHT" style="-fx-spacing: 20; -fx-alignment: center; -fx-fill-width: true; -fx-max-width: infinity;">
                <Label text="欢迎，TA申请人" textFill="rgba(255,255,255,0.85)" />
                <Button text="退出" styleClass="btn btn-secondary" />
            </HBox>
        </HBox>
    </VBox>
    
    <!-- 主内容区 -->
    <VBox layoutY="80.0" alignment="CENTER" spacing="40.0" style="-fx-padding: 40px; -fx-fill-width: true;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="80.0">
        <VBox alignment="CENTER" spacing="16">
            <Label text="完善个人档案" styleClass="section-title" />
            <Label text="请填写以下信息以完善您的个人档案" textFill="#6c757d" style="-fx-font-size: 14px;" />
        </VBox>
        
        <VBox styleClass="container shadow-lg" maxWidth="840" style="-fx-pref-width: 90%;" spacing="32.0">
            <GridPane hgap="24.0" vgap="20.0" style="-fx-max-width: 100%;">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" />
                </columnConstraints>
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="8.0" style="-fx-pref-width: 100%;">
                    <Label text="姓名" styleClass="form-label" />
                    <TextField fx:id="nameField" styleClass="form-field" style="-fx-pref-width: 100%;" />
                </VBox>
                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="8.0" style="-fx-pref-width: 100%;">
                    <Label text="性别" styleClass="form-label" />
                    <TextField fx:id="genderField" styleClass="form-field" style="-fx-pref-width: 100%;" />
                </VBox>
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="8.0" style="-fx-pref-width: 100%;">
                    <Label text="年龄" styleClass="form-label" />
                    <TextField fx:id="ageField" styleClass="form-field" style="-fx-pref-width: 100%;" />
                </VBox>
                <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="8.0" style="-fx-pref-width: 100%;">
                    <Label text="所属院系" styleClass="form-label" />
                    <TextField fx:id="departmentField" styleClass="form-field" style="-fx-pref-width: 100%;" />
                </VBox>
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" spacing="8.0" style="-fx-pref-width: 100%;">
                    <Label text="年级" styleClass="form-label" />
                    <TextField fx:id="gradeField" styleClass="form-field" style="-fx-pref-width: 100%;" />
                </VBox>
                <VBox GridPane.columnIndex="1" GridPane.rowIndex="2" spacing="8.0" style="-fx-pref-width: 100%;">
                    <Label text="可工作时间段" styleClass="form-label" />
                    <TextField fx:id="availableTimeField" styleClass="form-field" style="-fx-pref-width: 100%;" />
                </VBox>
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2" spacing="8.0" style="-fx-pref-width: 100%;">
                    <Label text="擅长科目/技能（用分号分隔）" styleClass="form-label" />
                    <TextField fx:id="skillsField" styleClass="form-field" style="-fx-pref-width: 100%;" />
                </VBox>
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2" spacing="8.0" style="-fx-pref-width: 100%;">
                    <Label text="过往TA经验" styleClass="form-label" />
                    <TextArea fx:id="experienceField" styleClass="form-field" prefHeight="100.0" style="-fx-pref-width: 100%;" />
                </VBox>
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2" spacing="8.0" style="-fx-pref-width: 100%;">
                    <Label text="获奖情况（选填）" styleClass="form-label" />
                    <TextArea fx:id="awardsField" styleClass="form-field" prefHeight="80.0" style="-fx-pref-width: 100%;" />
                </VBox>
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="6" GridPane.columnSpan="2" spacing="8.0" style="-fx-pref-width: 100%;">
                    <Label text="语言能力（选填）" styleClass="form-label" />
                    <TextField fx:id="languageSkillsField" styleClass="form-field" style="-fx-pref-width: 100%;" />
                </VBox>
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.columnSpan="2" spacing="8.0" style="-fx-pref-width: 100%;">
                    <Label text="其他特长（选填）" styleClass="form-label" />
                    <TextArea fx:id="otherSkillsField" styleClass="form-field" prefHeight="80.0" style="-fx-pref-width: 100%;" />
                </VBox>
            </GridPane>
            
            <Label fx:id="messageLabel" styleClass="error-message" />
            
            <HBox spacing="16.0" alignment="CENTER" style="-fx-spacing: 16; -fx-wrap-text: true; -fx-pref-width: 100%;">
                <Button text="保存为草稿" styleClass="btn btn-secondary" onAction="#handleSaveDraft" style="-fx-pref-width: 32%;" />
                <Button text="提交审核" styleClass="btn btn-primary" onAction="#handleSubmitForReview" style="-fx-pref-width: 32%;" />
                <Button text="返回" styleClass="btn btn-secondary" onAction="#handleBack" style="-fx-pref-width: 32%;" />
            </HBox>
        </VBox>
    </VBox>
</AnchorPane>