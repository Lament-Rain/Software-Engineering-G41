<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="createJobPane" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MOCreateJobController">
    <VBox alignment="CENTER" spacing="0" styleClass="root" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox styleClass="navbar" spacing="24" alignment="CENTER_LEFT" style="-fx-padding: 0 24px;">
            <Label text="BUPT International School TA Recruitment System" styleClass="navbar-title" />
            <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-padding: 0 24px;">
                <Button text="Home" styleClass="navbar-menu" onAction="#handleHome" />
                <Button text="Create Job" styleClass="navbar-menu active" />
                <Button text="Application Review" styleClass="navbar-menu" />
                <Button text="Job Board" styleClass="navbar-menu" />
            </HBox>
            <HBox spacing="16" alignment="CENTER_RIGHT" style="-fx-padding: 0 24px; -fx-fill-width: true; -fx-alignment: center-right;">
                <Label fx:id="welcomeLabel" style="-fx-text-fill: white; -fx-font-size: 14px;" />
                <Button text="Logout" styleClass="btn btn-secondary" onAction="#handleLogout" style="-fx-min-width: 80px;" />
            </HBox>
        </HBox>

        <ScrollPane style="-fx-background-color: #f8f9fa;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
            <VBox alignment="CENTER" spacing="32" style="-fx-padding: 32px; -fx-fill-width: true; -fx-background-color: #f8f9fa; -fx-alignment: center; -fx-pref-width: 1200px;">
                <VBox alignment="CENTER" spacing="8">
                    <Label text="Create TA Position" styleClass="section-title" />
                    <Label text="Fill in the details below to publish a new opening" styleClass="subtitle" />
                </VBox>

                <VBox styleClass="container shadow-lg" maxWidth="800" style="-fx-pref-width: 90%; -fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 32px;" spacing="24">
                    <GridPane hgap="16" vgap="16" style="-fx-pref-width: 100%;">
                        <Label text="Job Title" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="titleField" promptText="Enter the job title" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.columnSpan="3" />

                        <Label text="Job Type" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <ComboBox fx:id="typeComboBox" promptText="Select job type" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Department" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <ComboBox fx:id="departmentComboBox" promptText="Select department" styleClass="form-field" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                        <Label text="Work Time" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="workTimeField" promptText="Example: 10 hours per week" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.columnSpan="3" />

                        <Label text="Openings" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <TextField fx:id="recruitNumField" promptText="Enter number of openings" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="Deadline" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                        <TextField fx:id="deadlineField" promptText="Example: 2026-04-30" styleClass="form-field" GridPane.columnIndex="3" GridPane.rowIndex="3" />

                        <Label text="Job Description" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <TextArea fx:id="descriptionArea" promptText="Describe the responsibilities and expectations" styleClass="form-field" style="-fx-min-height: 120px;" GridPane.columnIndex="1" GridPane.rowIndex="4" GridPane.columnSpan="3" />

                        <Label text="Skills" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <TextArea fx:id="skillsArea" promptText="Enter skills separated by commas" styleClass="form-field" style="-fx-min-height: 80px;" GridPane.columnIndex="1" GridPane.rowIndex="5" GridPane.columnSpan="3" />
                    </GridPane>

                    <Label fx:id="errorMessage" styleClass="error-message" />

                    <HBox spacing="16" alignment="CENTER" style="-fx-pref-width: 100%;">
                        <Button fx:id="cancelButton" text="Cancel" styleClass="btn btn-secondary" onAction="#handleCancel" style="-fx-pref-width: 120px;" />
                        <Button fx:id="submitButton" text="Publish Job" styleClass="btn btn-primary" onAction="#handleSubmit" style="-fx-pref-width: 120px;" />
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
