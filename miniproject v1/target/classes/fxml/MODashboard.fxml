<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="moDashboardPane" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MODashboardController">
    <VBox styleClass="navbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24 20 24; -fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true;">
            <Label text="BUPT International School TA Recruitment System" styleClass="navbar-title" />
            <HBox style="-fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true; -fx-max-width: infinity;">
                <Button text="Home" styleClass="navbar-menu active" onAction="#handleHome" />
                <Button text="Job Board" styleClass="navbar-menu" onAction="#handleJobManagement" />
                <Button text="Application Review" styleClass="navbar-menu" onAction="#handleApplicationManagement" />
            </HBox>
            <HBox style="-fx-spacing: 24; -fx-alignment: center;">
                <Label text="Welcome, Module Organizer" textFill="rgba(255,255,255,0.85)" />
                <Separator orientation="VERTICAL" styleClass="navbar-separator" />
                <Button text="Logout" styleClass="navbar-menu" onAction="#handleLogout" />
            </HBox>
        </HBox>
    </VBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: #f8f9fa;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
        <VBox style="-fx-padding: 32px; -fx-spacing: 32px; -fx-fill-width: true; -fx-background-color: #f8f9fa; -fx-alignment: center; -fx-pref-width: 1240px;">
            <HBox alignment="CENTER_LEFT" style="-fx-spacing: 16; -fx-fill-width: true;">
                <VBox style="-fx-spacing: 8;">
                    <Label text="Module Organizer Dashboard" styleClass="section-title" />
                    <Label text="Manage job postings and review applications" textFill="#6c757d" style="-fx-font-size: 14px;" />
                </VBox>
            </HBox>

            <HBox style="-fx-spacing: 24; -fx-fill-width: true; -fx-alignment: center;">
                <VBox styleClass="stat-card shadow-md" style="-fx-pref-width: 32%; -fx-min-width: 200px; -fx-max-width: 300px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px; -fx-spacing: 16;">
                    <Label text="📋" style="-fx-font-size: 32px;" />
                    <Label fx:id="publishedJobsLabel" text="0" styleClass="stat-value" />
                    <Label text="My Jobs" styleClass="stat-label" />
                </VBox>
                <VBox styleClass="stat-card shadow-md" style="-fx-pref-width: 32%; -fx-min-width: 200px; -fx-max-width: 300px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px; -fx-spacing: 16;">
                    <Label text="👥" style="-fx-font-size: 32px;" />
                    <Label fx:id="totalApplicationsLabel" text="0" styleClass="stat-value" />
                    <Label text="Total Applications" styleClass="stat-label" />
                </VBox>
                <VBox styleClass="stat-card shadow-md" style="-fx-pref-width: 32%; -fx-min-width: 200px; -fx-max-width: 300px; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px; -fx-spacing: 16;">
                    <Label text="✅" style="-fx-font-size: 32px;" />
                    <Label fx:id="acceptedApplicationsLabel" text="0" styleClass="stat-value" />
                    <Label text="Accepted Applicants" styleClass="stat-label" />
                </VBox>
            </HBox>

            <VBox styleClass="card shadow-md" style="-fx-pref-height: 340px; -fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <HBox alignment="CENTER_LEFT" style="-fx-spacing: 16; -fx-fill-width: true; -fx-padding: 0 0 20 0;">
                    <VBox style="-fx-spacing: 8;" HBox.hgrow="ALWAYS">
                        <Label text="My Posted Jobs" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057;" />
                        <Label text="Review every position you created. Double-click a row to open My Jobs." textFill="#6c757d" style="-fx-font-size: 14px;" />
                    </VBox>
                </HBox>
                <TableView fx:id="jobsTable" style="-fx-pref-height: 250px; -fx-fixed-cell-size: 36px; -fx-font-size: 12px;">
                    <columns>
                        <TableColumn text="Title" prefWidth="280">
                            <cellValueFactory>
                                <PropertyValueFactory property="title" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Department" prefWidth="170">
                            <cellValueFactory>
                                <PropertyValueFactory property="department" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Deadline" prefWidth="190">
                            <cellValueFactory>
                                <PropertyValueFactory property="deadline" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Status" prefWidth="150">
                            <cellValueFactory>
                                <PropertyValueFactory property="status" />
                            </cellValueFactory>
                        </TableColumn>
                        <TableColumn text="Applications" prefWidth="110">
                            <cellValueFactory>
                                <PropertyValueFactory property="applicationCount" />
                            </cellValueFactory>
                        </TableColumn>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" style="-fx-spacing: 8; -fx-padding: 30px;">
                            <Label text="No jobs created yet" style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #5c6b7a;" />
                            <Label text="Use Create Job below to publish your first opening" style="-fx-font-size: 12px; -fx-text-fill: #8b97a3;" />
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>

            <VBox styleClass="card shadow-md" style="-fx-fill-width: true; -fx-background-color: #ffffff; -fx-background-radius: 12px; -fx-padding: 24px;">
                <Label text="Quick Actions" style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #495057; -fx-padding: 0 0 20 0;" />
                <HBox style="-fx-spacing: 16; -fx-alignment: center-left; -fx-fill-width: true;">
                    <Button text="Create Job" styleClass="btn btn-primary" onAction="#handleCreateJob" style="-fx-pref-width: 180px; -fx-min-height: 40px;" />
                    <Button text="My Jobs" styleClass="btn btn-primary" onAction="#handleViewMyJobs" style="-fx-pref-width: 180px; -fx-min-height: 40px;" />
                    <Button text="Application Review" styleClass="btn btn-primary" onAction="#handleViewApplications" style="-fx-pref-width: 180px; -fx-min-height: 40px;" />
                    <Button text="Export Application Data" styleClass="btn btn-secondary" onAction="#handleExportData" style="-fx-pref-width: 200px; -fx-min-height: 40px;" />
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</AnchorPane>
