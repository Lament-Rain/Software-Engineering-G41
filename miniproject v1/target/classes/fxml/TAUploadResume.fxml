<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="uploadResumePane" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TAUploadResumeController">
    <!-- Navigation Bar -->
    <VBox styleClass="navbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 24 20 24; -fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true;">
            <Label text="BUPT International School TA Recruitment System" styleClass="navbar-title" />
            <HBox style="-fx-spacing: 24; -fx-alignment: center; -fx-fill-width: true; -fx-max-width: infinity;">
                <Button text="Home" styleClass="navbar-menu" onAction="#handleHome" />
                <Button text="Job Requirements" styleClass="navbar-menu" onAction="#handleJobRequirements" />
                <Button text="Application Management" styleClass="navbar-menu" onAction="#handleApplicationManagement" />
                <Button text="Personal Center" styleClass="navbar-menu" onAction="#handlePersonalCenter" />
            </HBox>
            <HBox alignment="CENTER_RIGHT" style="-fx-spacing: 16; -fx-alignment: center;">
                <Label text="Welcome, TA Applicant" textFill="rgba(255,255,255,0.85)" />
                <Button text="Back to TA Dashboard" styleClass="navbar-menu" onAction="#handleBack" />
                <Button text="Logout" styleClass="navbar-menu" onAction="#handleLogout" />
            </HBox>
        </HBox>
    </VBox>
    
    <!-- Main Content Area -->
    <VBox alignment="CENTER" spacing="48.0" style="-fx-padding: 48px; -fx-fill-width: true; -fx-background-color: #f8f9fa; -fx-alignment: center;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="70.0">
        <VBox alignment="CENTER" spacing="16">
            <Label text="Upload Resume" styleClass="section-title" />
            <Label text="Please select and upload your resume file" textFill="#6c757d" style="-fx-font-size: 14px;" />
        </VBox>
        
        <VBox styleClass="container shadow-lg" maxWidth="600" style="-fx-pref-width: 90%; -fx-background-color: #ffffff; -fx-background-radius: 12px;" spacing="32.0">
            <VBox style="-fx-padding: 32px; -fx-spacing: 24;">
                <Label text="Please select resume file (PDF only, size no more than 10MB)" style="-fx-font-size: 14px; -fx-text-fill: #495057;" />
                <HBox spacing="16.0" alignment="CENTER" style="-fx-spacing: 16; -fx-fill-width: true;">
                    <TextField fx:id="filePathField" styleClass="form-field" editable="false" style="-fx-pref-width: 70%; -fx-min-height: 40px;" />
                    <Button text="Browse" styleClass="btn btn-secondary" onAction="#handleBrowse" style="-fx-pref-width: 100px; -fx-min-height: 40px;" />
                </HBox>
                <ProgressBar fx:id="progressBar" progress="0" visible="false" style="-fx-pref-width: 100%; -fx-min-height: 8px;" />
                <Label fx:id="messageLabel" styleClass="error-message" />
                <HBox spacing="16.0" alignment="CENTER" style="-fx-spacing: 16; -fx-wrap-text: true; -fx-fill-width: true;">
                    <Button text="Upload" styleClass="btn btn-primary" onAction="#handleUpload" style="-fx-pref-width: 120px; -fx-min-height: 40px;" />
                    <Button text="View Resume" styleClass="btn btn-secondary" onAction="#handleViewResume" style="-fx-pref-width: 120px; -fx-min-height: 40px;" />
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</AnchorPane>