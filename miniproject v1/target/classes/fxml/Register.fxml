<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="registerPane" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RegisterController">
    <VBox alignment="CENTER" spacing="0" styleClass="root" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <HBox prefHeight="8">
            <Region styleClass="bg-primary" style="-fx-pref-width: 25%;" />
            <Region styleClass="bg-secondary" style="-fx-pref-width: 25%;" />
            <Region styleClass="bg-accent" style="-fx-pref-width: 25%;" />
            <Region styleClass="bg-success" style="-fx-pref-width: 25%;" />
        </HBox>

        <ScrollPane style="-fx-background-color: #f8f9fa;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="8.0">
            <VBox alignment="CENTER" spacing="64" style="-fx-padding: 48px; -fx-fill-width: true; -fx-background-color: #f8f9fa; -fx-alignment: center; -fx-pref-width: 1200px;">
                <VBox alignment="CENTER" styleClass="container shadow-lg" maxWidth="680" style="-fx-pref-width: 90%; -fx-background-color: #ffffff; -fx-background-radius: 12px;" spacing="32">
                    <VBox alignment="CENTER" spacing="16" style="-fx-fill-width: true; -fx-padding: 32px 32px 0 32px;">
                        <Label text="BUPT International School TA Recruitment System" styleClass="title" />
                        <Label text="Create a new account" styleClass="subtitle" />
                    </VBox>

                    <VBox spacing="16" style="-fx-padding: 16px 32px 0 32px; -fx-pref-width: 100%;">
                        <Label text="Select Role" styleClass="form-label" />
                        <HBox spacing="16" alignment="CENTER" style="-fx-pref-width: 100%;">
                            <ToggleButton fx:id="taToggle" text="TA Applicant" styleClass="btn btn-secondary" style="-fx-pref-width: 160px; -fx-min-height: 44px; -fx-font-size: 14px;" />
                            <ToggleButton fx:id="moToggle" text="Module Organizer" styleClass="btn btn-secondary" style="-fx-pref-width: 160px; -fx-min-height: 44px; -fx-font-size: 14px;" />
                            <ToggleButton fx:id="adminToggle" text="System Admin" styleClass="btn btn-secondary" style="-fx-pref-width: 160px; -fx-min-height: 44px; -fx-font-size: 14px;" />
                        </HBox>
                    </VBox>

                    <VBox spacing="20" style="-fx-pref-width: 100%; -fx-padding: 0 32px;">
                        <HBox spacing="24" style="-fx-pref-width: 100%;">
                            <VBox spacing="8" style="-fx-pref-width: 50%;">
                                <Label text="Email" styleClass="form-label" />
                                <TextField fx:id="emailField" promptText="Enter your email" styleClass="form-field" style="-fx-pref-width: 100%; -fx-min-height: 40px;" />
                            </VBox>
                            <VBox spacing="8" style="-fx-pref-width: 50%;">
                                <Label text="Password" styleClass="form-label" />
                                <PasswordField fx:id="passwordField" promptText="Enter password (at least 8 characters)" styleClass="form-field" style="-fx-pref-width: 100%; -fx-min-height: 40px;" />
                            </VBox>
                        </HBox>
                        <HBox spacing="24" style="-fx-pref-width: 100%;">
                            <VBox spacing="8" style="-fx-pref-width: 50%;">
                                <Label text="Confirm Password" styleClass="form-label" />
                                <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" styleClass="form-field" style="-fx-pref-width: 100%; -fx-min-height: 40px;" />
                            </VBox>
                            <VBox spacing="8" style="-fx-pref-width: 50%;">
                                <Label text="Username" styleClass="form-label" />
                                <TextField fx:id="usernameField" promptText="Enter a username" styleClass="form-field" style="-fx-pref-width: 100%; -fx-min-height: 40px;" />
                            </VBox>
                        </HBox>
                        <HBox spacing="24" style="-fx-pref-width: 100%;">
                            <VBox spacing="8" style="-fx-pref-width: 50%;">
                                <Label text="Phone" styleClass="form-label" />
                                <TextField fx:id="phoneField" promptText="Enter your phone number" styleClass="form-field" style="-fx-pref-width: 100%; -fx-min-height: 40px;" />
                            </VBox>
                            <VBox spacing="8" style="-fx-pref-width: 50%;">
                                <Label text="Department" styleClass="form-label" />
                                <TextField fx:id="departmentField" promptText="Required for Module Organizer" styleClass="form-field" style="-fx-pref-width: 100%; -fx-min-height: 40px;" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox spacing="16" style="-fx-padding: 0 32px;">
                        <Label fx:id="errorMessage" styleClass="error-message" />
                        <Label fx:id="successMessage" styleClass="success-message" />
                    </VBox>

                    <HBox spacing="16" alignment="CENTER" style="-fx-pref-width: 100%; -fx-padding: 0 32px 32px 32px;">
                        <Button fx:id="backButton" text="Back to Login" styleClass="btn btn-secondary" onAction="#handleBack" style="-fx-pref-width: 160px; -fx-min-height: 44px; -fx-font-size: 14px;" />
                        <Button fx:id="registerButton" text="Create Account" styleClass="btn btn-primary" onAction="#handleRegister" style="-fx-pref-width: 160px; -fx-min-height: 44px; -fx-font-size: 14px;" />
                    </HBox>
                </VBox>

                <VBox alignment="CENTER" style="-fx-padding: 16px 0;">
                    <Label text="© 2026 BUPT International School. All rights reserved." textFill="#6c757d" style="-fx-font-size: 12px;" />
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</AnchorPane>
